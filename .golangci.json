{
    "_ignore": "DO NOT MODIFY THIS FILE: https://github.com/honestbank/.github/blob/main/docs/about.md",
    "run": {
        "tests": true
    },
    "linters": {
        "disable-all": true,
        "enable": [
            "errcheck",
            "gosimple",
            "govet",
            "ineffassign",
            "staticcheck",
            "unused",
            "gofmt",
            "goimports",
            "nestif",
            "asciicheck",
            "exhaustive",
            "forbidigo",
            "gocyclo",
            "makezero",
            "misspell",
            "nakedret",
            "nilerr",
            "nlreturn",
            "nolintlint",
            "testpackage",
            "unconvert",
            "whitespace"
        ]
    },
    "issues": {
        "exclude-files": [
            "graph"
        ],
        "exclude-dirs": [
            ".*/generated/*",
            "examples"
        ],
        "exclude-dirs-use-default": true,
        "exclude-rules": [
            {
                "path": "_test\\.go",
                "linters": ["errcheck"]
            }
        ]
    }
}
